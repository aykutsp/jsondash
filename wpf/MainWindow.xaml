<Window x:Class="JsonDash.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:JsonDash.Wpf.Models"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="jsondash WPF"
        Height="980"
        Width="1360"
        MinWidth="1080"
        MinHeight="820"
        Background="#F4ECE3">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Background" Value="#FFF9F3" />
            <Setter Property="BorderBrush" Value="#140F2233" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Background" Value="#10243310" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Style="{StaticResource PanelBorderStyle}"
                    Padding="28"
                    Background="#FFF8F3"
                    BorderBrush="#180F2233">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="WPF implementation"
                                   Foreground="#8A6720"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="Desktop-first JSON dashboards without leaving Windows."
                                   Margin="0,10,0,14"
                                   FontFamily="Bahnschrift"
                                   FontSize="42"
                                   FontWeight="SemiBold"
                                   Foreground="#122433"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Load a local file, restore the shared sample, and review trend lines, grouped summaries, and source rows in a single native desktop window."
                                   Foreground="#5F6E82"
                                   FontSize="15"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,20,0,0">
                            <Border Style="{StaticResource ChipStyle}"><TextBlock Text="React" Foreground="#284251" /></Border>
                            <Border Style="{StaticResource ChipStyle}"><TextBlock Text="Angular" Foreground="#284251" /></Border>
                            <Border Style="{StaticResource ChipStyle}" Background="#22E2B75B"><TextBlock Text="WPF" Foreground="#6B4C09" /></Border>
                            <Border Style="{StaticResource ChipStyle}"><TextBlock Text="Flask" Foreground="#284251" /></Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Padding="20"
                            CornerRadius="22"
                            Background="#17374C">
                        <StackPanel>
                            <TextBlock Text="Source"
                                       Foreground="#DAB66A"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SourceLabel}"
                                       Margin="0,10,0,6"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#FFF7F0"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       Foreground="#D9E3EA"
                                       TextWrapping="Wrap" />

                            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                <Button Content="Open JSON file"
                                        Width="142"
                                        Height="40"
                                        Margin="0,0,12,0"
                                        Background="#EFBB49"
                                        Foreground="#17374C"
                                        BorderBrush="{x:Null}"
                                        Click="OpenFileButton_Click" />
                                <Button Content="Load sample"
                                        Width="120"
                                        Height="40"
                                        Background="#22FFFFFF"
                                        Foreground="#FFF7F0"
                                        BorderBrush="{x:Null}"
                                        Click="LoadSampleButton_Click" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,16">
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Dataset" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock x:Name="DatasetNameText"
                                   Margin="0,10,0,0"
                                   Text="root"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#122433" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Rows" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding RowCount}"
                                   Margin="0,10,0,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#122433" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                    <StackPanel>
                        <TextBlock Text="Numeric fields" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding NumericFieldCount}"
                                   Margin="0,10,0,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#122433" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0">
                    <StackPanel>
                        <TextBlock Text="Category fields" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding CategoryFieldCount}"
                                   Margin="0,10,0,0"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#122433" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Field scan" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Automatic structure detection"
                                   Margin="0,10,0,16"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#122433" />
                        <ItemsControl ItemsSource="{Binding FieldTags}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding}" Foreground="#284251" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Numeric summary" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="Fast read on the metrics"
                                   Margin="0,10,0,16"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#122433" />
                        <ItemsControl ItemsSource="{Binding SummaryItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:SummaryItem}">
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#122433" />
                                            <TextBlock Text="{Binding Avg, StringFormat=Avg {0}}" Foreground="#5F6E82" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Min, StringFormat=Min {0}}" Foreground="#5F6E82" />
                                            <TextBlock Text="{Binding Max, StringFormat=Max {0}}" Foreground="#5F6E82" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <ItemsControl Grid.Row="3" ItemsSource="{Binding ChartCards}" Margin="0,0,0,16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="620" Margin="0,0,16,16" Style="{StaticResource PanelBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Foreground="#122433" />

                                <Grid Margin="0,16,0,0"
                                      Visibility="{Binding IsLineChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="180" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Border CornerRadius="18" Background="#FFF3E1">
                                        <Canvas Width="420" Height="170" Margin="18,8">
                                            <Polyline Points="{Binding Points}" Stroke="#17374C" StrokeThickness="3" />
                                        </Canvas>
                                    </Border>
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" Margin="0,16,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource ChipStyle}">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Label}" Foreground="#284251" />
                                                        <TextBlock Text="{Binding Value}" FontWeight="SemiBold" Foreground="#122433" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>

                                <ItemsControl Margin="0,16,0,0"
                                              ItemsSource="{Binding Items}"
                                              Visibility="{Binding IsBarChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding Label}" Foreground="#122433" />
                                                <ProgressBar Grid.Column="1"
                                                             Height="12"
                                                             Margin="12,0"
                                                             Maximum="100"
                                                             Value="{Binding Percent}"
                                                             Foreground="#17374C"
                                                             Background="#FFE2D6C6" />
                                                <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding Value}" Foreground="#5F6E82" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Grid.Row="4" Style="{StaticResource PanelBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Apex gallery" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                        <TextBlock Text="All major Apex chart families in one live demo"
                                   Margin="0,10,0,8"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#122433" />
                        <TextBlock Text="This embedded surface gives the WPF app the same broad chart-family coverage as the web demos."
                                   Foreground="#5F6E82"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            CornerRadius="22"
                            BorderBrush="#140F2233"
                            BorderThickness="1"
                            Height="1720"
                            Background="#0F1722">
                        <wv2:WebView2 x:Name="ApexGalleryView" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource PanelBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Data explorer" Foreground="#8A6720" FontSize="12" FontWeight="SemiBold" />
                            <TextBlock Text="Search and inspect the source rows"
                                       Margin="0,10,0,0"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="#122433" />
                        </StackPanel>
                        <Border Grid.Column="1" Padding="14,8" Background="#10243310" CornerRadius="999" VerticalAlignment="Top">
                            <TextBlock x:Name="VisibleRowsText" Foreground="#284251" Text="0 visible rows" />
                        </Border>
                    </Grid>

                    <TextBox Grid.Row="1"
                             x:Name="SearchTextBox"
                             Margin="0,18,0,18"
                             Padding="14"
                             BorderThickness="1"
                             BorderBrush="#1A102433"
                             Background="#FFFFFFFF"
                             FontSize="14"
                             TextChanged="SearchTextBox_TextChanged" />

                    <DataGrid Grid.Row="2"
                              x:Name="RowsGrid"
                              AutoGenerateColumns="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0"
                              Background="Transparent" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
